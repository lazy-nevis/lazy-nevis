{
  "$schema": "./schemas/catalog.schema.json",
  "version": 1,
  "defaults": {
    "locale": "en-US",
    "settleMs": 700,
    "window": "main",
    "mode": "full",
    "required": true
  },
  "shots": [
    {
      "id": "dashboard-idle-light",
      "file": "dashboard-idle-light.png",
      "legacyFilenames": ["dashboard-light.png"],
      "route": "/",
      "feature": "dashboard",
      "state": "idle",
      "theme": "light",
      "sessionPose": "idle",
      "title": "Dashboard with no active session (light)",
      "tags": ["readme", "docs", "hero"]
    },
    {
      "id": "dashboard-idle-dark",
      "file": "dashboard-idle-dark.png",
      "legacyFilenames": ["dashboard-dark.png"],
      "route": "/",
      "feature": "dashboard",
      "state": "idle",
      "theme": "dark",
      "sessionPose": "idle",
      "title": "Dashboard with no active session (dark)",
      "tags": ["readme", "docs", "hero"]
    },
    {
      "id": "dashboard-running-light",
      "file": "dashboard-running-light.png",
      "route": "/",
      "feature": "focus-session",
      "state": "running_focused",
      "theme": "light",
      "sessionPose": "running_focused",
      "title": "Dashboard with an active focused session (light)",
      "tags": ["readme", "docs", "hero", "session"]
    },
    {
      "id": "dashboard-running-dark",
      "file": "dashboard-running-dark.png",
      "route": "/",
      "feature": "focus-session",
      "state": "running_focused",
      "theme": "dark",
      "sessionPose": "running_focused",
      "title": "Dashboard with an active focused session (dark)",
      "tags": ["readme", "docs", "hero", "session"]
    },
    {
      "id": "history-light",
      "file": "history-light.png",
      "route": "/history",
      "feature": "history",
      "state": "seeded",
      "theme": "light",
      "sessionPose": "idle",
      "title": "History with seeded sessions and charts (light)",
      "tags": ["readme", "docs", "history"]
    },
    {
      "id": "history-dark",
      "file": "history-dark.png",
      "route": "/history",
      "feature": "history",
      "state": "seeded",
      "theme": "dark",
      "sessionPose": "idle",
      "title": "History with seeded sessions and charts (dark)",
      "tags": ["readme", "docs", "history"]
    },
    {
      "id": "settings-light",
      "file": "settings-light.png",
      "route": "/settings",
      "feature": "settings",
      "state": "focus-rules",
      "theme": "light",
      "sessionPose": "idle",
      "settingsTab": "focus_rules",
      "title": "Settings showing focus rules (light)",
      "tags": ["readme", "docs", "settings"]
    },
    {
      "id": "settings-dark",
      "file": "settings-dark.png",
      "route": "/settings",
      "feature": "settings",
      "state": "focus-rules",
      "theme": "dark",
      "sessionPose": "idle",
      "settingsTab": "focus_rules",
      "title": "Settings showing focus rules (dark)",
      "tags": ["readme", "docs", "settings"]
    },
    {
      "id": "fullscreen-alert",
      "file": "fullscreen-alert.png",
      "window": "overlay",
      "route": "/overlay",
      "feature": "alerts",
      "state": "fullscreen-overlay",
      "theme": "dark",
      "sessionPose": "running_distracted",
      "overlayPose": "fullscreen",
      "title": "Fullscreen overlay alert in action",
      "tags": ["readme", "docs", "alerts"]
    },
    {
      "id": "notification-alert",
      "file": "notification-alert.png",
      "window": "main",
      "route": "/",
      "feature": "alerts",
      "state": "notification",
      "theme": "light",
      "sessionPose": "running_distracted",
      "overlayPose": "notification",
      "title": "Native-style notification alert context",
      "tags": ["readme", "docs", "alerts"],
      "notes": "May capture main window + notification chrome depending on OS adapter capabilities."
    },
    {
      "id": "checklist-light",
      "file": "checklist-light.png",
      "route": "/checklist",
      "feature": "checklist",
      "state": "seeded",
      "theme": "light",
      "sessionPose": "idle",
      "title": "Daily checklist with seeded items (light)",
      "tags": ["docs", "checklist"],
      "required": false
    },
    {
      "id": "about-light",
      "file": "about-light.png",
      "route": "/about",
      "feature": "about",
      "state": "default",
      "theme": "light",
      "sessionPose": "idle",
      "title": "About page (light)",
      "tags": ["docs", "about"],
      "required": false
    },
    {
      "id": "compact-running-dark",
      "file": "compact-running-dark.png",
      "route": "/",
      "feature": "app-modes",
      "state": "compact-running",
      "theme": "dark",
      "mode": "compact",
      "sessionPose": "running_focused",
      "title": "Compact mode with active session (dark)",
      "tags": ["docs", "compact", "session"],
      "required": false
    },
    {
      "id": "tray-running",
      "file": "tray-running.png",
      "window": "tray",
      "route": "/tray",
      "feature": "tray-quick-panel",
      "state": "running",
      "theme": "dark",
      "sessionPose": "running_focused",
      "title": "Tray quick panel with active session",
      "tags": ["docs", "tray"],
      "required": false
    },
    {
      "id": "secondary-settings",
      "file": "secondary-settings.png",
      "window": "secondary",
      "route": "/secondary",
      "pane": "settings",
      "feature": "app-modes",
      "state": "secondary-settings",
      "theme": "light",
      "mode": "compact",
      "sessionPose": "running_focused",
      "title": "Secondary window Settings pane from Compact Mode",
      "tags": ["docs", "secondary"],
      "required": false
    }
  ]
}
