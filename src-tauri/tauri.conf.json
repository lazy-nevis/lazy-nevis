{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LazyNevis",
  "version": "0.10.0-rc.5",
  "identifier": "br.dev.sims.lazynevis",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "LazyNevis",
        "width": 900,
        "height": 680,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "center": true,
        "dragDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 20 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src 'self' https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "SIMSDEV",
    "copyright": "Copyright © 2026 Lucas Sims. MIT License.",
    "category": "Productivity",
    "shortDescription": "for lazy people who don't give upis.",
    "longDescription": "LazyNevis is a lightweight, open-source, cross-platform focus tool. It lives in your system tray, monitors your active window, and nudges you back on track when you drift — without blocking or judging. Built with Tauri, Rust, and React.",
    "icon": [
      "icons/32x32.png",
      "icons/96x96_monochrome.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "sounds/*": "sounds/",
      "icons/**/*": "icons/"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
